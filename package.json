{
  "name": "@moikapy/origen",
  "version": "0.5.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./dist/models.js",
      "default": "./dist/models.js"
    },
    "./soul": {
      "types": "./dist/soul.d.ts",
      "import": "./dist/soul.js",
      "default": "./dist/soul.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "default": "./dist/adapter.js"
    },
    "./wiki/local": {
      "types": "./dist/wiki/local.d.ts",
      "import": "./dist/wiki/local.js",
      "default": "./dist/wiki/local.js"
    },
    "./wiki/cloud": {
      "types": "./dist/wiki/cloud.d.ts",
      "import": "./dist/wiki/cloud.js",
      "default": "./dist/wiki/cloud.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup --no-dts --no-sourcemap",
    "build:release": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build:release"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.0",
    "@mariozechner/pi-ai": "^0.73.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^3"
  },
  "license": "MIT"
}
